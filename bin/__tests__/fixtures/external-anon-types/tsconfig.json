{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun", "reflect-metadata"],
    "baseUrl": ".",
    "paths": {
      "elysia-nest": ["../../../../index.ts"],
      "fake-orm": ["./_modules/fake-orm/index.d.ts"]
    }
  },
  "include": ["src/**/*"]
}
