{
  "$schema": "https://mintlify.com/docs.json",
  "name": "@kiyasov/elysia-nest",
  "theme": "aspen",
  "colors": {
    "primary": "#4f46e5",
    "light": "#818cf8",
    "dark": "#3730a3"
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "dracula"
      }
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Inter Display Bold",
      "source": "https://mintlify-assets.b-cdn.net/fonts/InterDisplay-Bold.woff2",
      "format": "woff2"
    }
  },
  "appearance": {
    "default": "system"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/kiyasov"
    }
  },
  "banner": {
    "content": "@kiyasov/elysia-nest is under active development. APIs may change before the stable release.",
    "dismissible": false
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/kiyasov/@kiyasov/elysia-nest"
        },
        {
          "anchor": "Elysia",
          "icon": "bolt",
          "href": "https://elysiajs.com"
        }
      ]
    },
    "tabs": [
