{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmitOnError": false,
    "outDir": "./dist/types",
    "paths": {
      "nestelia": ["./index.ts"],
      "~": ["./packages/core"],
      "~/*": ["./packages/core/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "examples",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
